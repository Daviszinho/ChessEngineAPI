# Configuración de Seguridad OWASP ZAP

# Puerto de la API
API_PORT=3000
API_HOST=localhost

# URL completa de la API para escaneos
API_URL=http://localhost:3000

# Configuración de ZAP
ZAP_PORT=8080
ZAP_HOST=localhost

# Tipo de escaneo por defecto
# Opciones: baseline, full, quick
SCAN_TYPE=baseline

# Directorio de reportes
REPORT_DIR=./security/zap-reports

# Configuración de Docker Compose
COMPOSE_FILE=docker-compose.yml
COMPOSE_PROJECT_NAME=chess-engine-api

# Perfil de docker-compose a usar
COMPOSE_PROFILES=security

# Timeouts
API_WAIT_TIMEOUT=30
ZAP_WAIT_TIMEOUT=30
SCAN_TIMEOUT=600

# Niveles de severidad que causan fallo
FAIL_ON_CRITICAL=true
FAIL_ON_HIGH=true

# Mostrar output detallado
VERBOSE=false

# Ambiente
NODE_ENV=development

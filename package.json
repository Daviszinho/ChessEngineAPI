{
  "name": "chess-engine-api",
  "version": "1.0.0",
  "description": "REST API facade for multiple chess engines",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "test": "vitest run --coverage --run"
  },
  "dependencies": {
    "chess.js": "^1.0.0",
    "cors": "^2.8.5",
    "express": "^5.2.1",
    "helmet": "^8.1.0",
    "joi": "^18.0.2",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.0.18",
    "nodemon": "^3.0.1",
    "supertest": "^7.2.2",
    "vitest": "^4.0.18"
  },
  "vitest": {
    "globals": true,
    "environment": "node",
    "include": ["test/**/*.js"]
  }
}
